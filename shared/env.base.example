# ==============================================================================
# Eter Agent Ecosystem — Shared Environment Variables (EXAMPLE)
# ==============================================================================
# This file contains API keys and config shared across ALL profiles.
# DO NOT edit individual profile .env files for shared keys.
# Instead, edit this file and run: scripts/setup-env.sh
#
# Individual overrides go in: profiles/<name>/.env.overrides
#
# IMPORTANT: Copy this file to shared/env.base and fill in your real API keys.
# Never commit shared/env.base to git — it contains secrets!
# ==============================================================================

# --- LLM Providers ---

# OpenCode Go (primary provider for all profiles)
OPENCODE_GO_API_KEY=sk-xxx-your-opencode-go-api-key-here
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

# z.ai / GLM
GLM_API_KEY=your-glm-api-key-here

# MiniMax
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.io/v1

# OpenRouter
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# --- Tool API Keys ---

# Exa Search
EXA_API_KEY=your-exa-api-key-here

# FAL.ai (Image generation)
FAL_KEY=your-fal-api-key-here

# Tinker (RL training)
TINKER_API_KEY=tml-your-tinker-api-key-here

# Weights & Biases
WANDB_API_KEY=your-wandb-api-key-here

# --- Platform Config ---

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOWED_USERS=your-telegram-user-id-here
TELEGRAM_HOME_CHANNEL=your-telegram-channel-id-here

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_ALLOWED_USERS=your-discord-user-id-here

# --- Infrastructure ---

# Terminal
TERMINAL_ENV=local
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
HERMES_MAX_ITERATIONS=150

# Browser
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false

# OpenViking
OPENVIKING_ENDPOINT=http://<OPENVIKING_HOST>:1933

# Sudo (for local terminal)
SUDO_PASSWORD=your-sudo-password-here

# Home Assistant
HASS_URL=http://<HASS_HOST>:8123
