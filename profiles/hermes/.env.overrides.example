# ============================================================
# .env.overrides — Profile-specific environment overrides
# ============================================================
# Values here override those from shared/env.base for this profile only.
# Copy this file to .env.overrides to use.
# ============================================================

# Example: Override the main model provider for this profile
# OPENCODE_GO_API_KEY=sk-different-key-for-this-profile

# Example: Use more iterations
# HERMES_MAX_ITERATIONS=200
